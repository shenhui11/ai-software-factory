name: 02-设计与测试设计

on:
  workflow_dispatch:
    inputs:
      feature_id:
        description: "需求编号，例如 FEAT-0001"
        required: true
        type: string

jobs:
  design:
    runs-on: ubuntu-latest
    permissions:
      contents: write

    env:
      FEATURE_ID: ${{ github.event.inputs.feature_id }}

    steps:
      - name: 检出代码
        uses: actions/checkout@v4

      - name: 校验 requirement 已审批
        run: |
          test -f "specs/review/${FEATURE_ID}.requirement.approved"

      - name: 安装 Node.js
        uses: actions/setup-node@v4
        with:
          node-version: "20"

      - name: 安装 Codex CLI
        run: npm install -g @openai/codex

      - name: 配置 Codex
        env:
          CODEX_BASE_URL: ${{ secrets.CODEX_BASE_URL }}
        run: |
          bash scripts/setup_codex.sh

      - name: 准备目录
        run: |
          mkdir -p specs/prd specs/architecture specs/test-plan specs/test-cases

      - name: 执行 Product Manager
        env:
          CODEX_API_KEY: ${{ secrets.CODEX_API_KEY }}
        run: |
          sed "s/{feature_id}/${FEATURE_ID}/g" specs/prompts/product-manager.md > /tmp/product.prompt
          codex exec --skip-git-repo-check "$(cat /tmp/product.prompt)"

      - name: 执行 Architect
        env:
          CODEX_API_KEY: ${{ secrets.CODEX_API_KEY }}
        run: |
          sed "s/{feature_id}/${FEATURE_ID}/g" specs/prompts/architect.md > /tmp/architect.prompt
          codex exec --skip-git-repo-check "$(cat /tmp/architect.prompt)"

      - name: 执行 Test Designer
        env:
          CODEX_API_KEY: ${{ secrets.CODEX_API_KEY }}
        run: |
          sed "s/{feature_id}/${FEATURE_ID}/g" specs/prompts/test-designer.md > /tmp/test.prompt
          codex exec --skip-git-repo-check "$(cat /tmp/test.prompt)"

      - name: 校验 02 输出
        run: |
          test -s "specs/prd/${FEATURE_ID}.md"
          test -s "specs/architecture/${FEATURE_ID}.md"
          test -s "specs/test-plan/${FEATURE_ID}.md"
          test -s "specs/test-cases/${FEATURE_ID}.yaml"

      - name: 提交 02 产物
        run: |
          git config user.name "Hui Shen"
          git config user.email "295225478@qq.com"
          git add -A
          git diff --cached --quiet || git commit -m "docs: generate design artifacts ${FEATURE_ID}"
          git push
