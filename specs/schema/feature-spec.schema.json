{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FeatureSpec",
  "type": "object",
  "required": [
    "feature_id",
    "title",
    "summary",
    "actors",
    "business_goal",
    "scope",
    "acceptance_criteria",
    "non_functional_requirements",
    "constraints",
    "deliverables"
  ],
  "properties": {
    "feature_id": {
      "type": "string",
      "pattern": "^FEAT-[0-9]{4}$"
    },
    "title": {
      "type": "string",
      "minLength": 5
    },
    "summary": {
      "type": "string",
      "minLength": 10
    },
    "business_goal": {
      "type": "string",
      "minLength": 10
    },
    "actors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "scope": {
      "type": "object",
      "required": ["in_scope", "out_of_scope"],
      "properties": {
        "in_scope": {
          "type": "array",
          "items": { "type": "string" }
        },
        "out_of_scope": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 3,
      "items": { "type": "string" }
    },
    "non_functional_requirements": {
      "type": "object",
      "required": ["security", "performance", "reliability", "observability"],
      "properties": {
        "security": {
          "type": "array",
          "items": { "type": "string" }
        },
        "performance": {
          "type": "array",
          "items": { "type": "string" }
        },
        "reliability": {
          "type": "array",
          "items": { "type": "string" }
        },
        "observability": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "deliverables": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "test_strategy": {
      "type": "object",
      "properties": {
        "unit": { "type": "array", "items": { "type": "string" } },
        "integration": { "type": "array", "items": { "type": "string" } },
        "e2e": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
