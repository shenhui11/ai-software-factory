{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Feature Intake Spec",
  "type": "object",
  "required": [
    "feature_id",
    "raw_requirement",
    "requirement_card_file",
    "manual_guidance",
    "product_context",
    "mvp_scope",
    "out_of_scope",
    "assumptions",
    "open_questions",
    "constraints",
    "actors",
    "acceptance_criteria"
  ],
  "properties": {
    "feature_id": {
      "type": "string"
    },
    "raw_requirement": {
      "type": "string"
    },
    "requirement_card_file": {
      "type": "string"
    },
    "manual_guidance": {
      "type": "array",
      "items": { "type": "string" }
    },
    "product_context": {
      "type": "object",
      "required": [
        "target_users",
        "business_goal",
        "problem_statement",
        "success_metrics"
      ],
      "properties": {
        "target_users": {
          "type": "array",
          "items": { "type": "string" }
        },
        "business_goal": {
          "type": "string"
        },
        "problem_statement": {
          "type": "string"
        },
        "success_metrics": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "mvp_scope": {
      "type": "array",
      "items": { "type": "string" }
    },
    "out_of_scope": {
      "type": "array",
      "items": { "type": "string" }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "constraints": {
      "type": "object",
      "required": ["tech_stack", "non_functional"],
      "properties": {
        "tech_stack": {
          "type": "array",
          "items": { "type": "string" }
        },
        "non_functional": {
          "type": "object",
          "required": [
            "security",
            "performance",
            "reliability",
            "observability"
          ],
          "properties": {
            "security": {
              "type": "array",
              "items": { "type": "string" }
            },
            "performance": {
              "type": "array",
              "items": { "type": "string" }
            },
            "reliability": {
              "type": "array",
              "items": { "type": "string" }
            },
            "observability": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "actors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": {
      "type": "string"
    }
  }
}
