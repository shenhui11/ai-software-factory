{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FeatureSpec",
  "type": "object",
  "required": [
    "feature_id",
    "raw_requirement",
    "selected_solution",
    "mvp_scope",
    "out_of_scope",
    "actors",
    "constraints",
    "acceptance_criteria",
    "decision_artifacts"
  ],
  "properties": {
    "feature_id": {
      "type": "string",
      "pattern": "^FEAT-[0-9]{4}$"
    },
    "raw_requirement": {
      "type": "string",
      "minLength": 5
    },
    "selected_solution": {
      "type": "object",
      "required": ["id", "name", "reason"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "mvp_scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "out_of_scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "actors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "constraints": {
      "type": "object",
      "required": ["tech_stack", "non_functional"],
      "properties": {
        "tech_stack": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "non_functional": {
          "type": "object",
          "required": [
            "security",
            "performance",
            "reliability",
            "observability"
          ],
          "properties": {
            "security": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "performance": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "reliability": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "observability": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decision_artifacts": {
      "type": "object",
      "required": [
        "brainstorm_file",
        "scoring_file",
        "decision_file"
      ],
      "properties": {
        "brainstorm_file": {
          "type": "string",
          "pattern": "^specs/brainstorm/FEAT-[0-9]{4}\\.md$"
        },
        "scoring_file": {
          "type": "string",
          "pattern": "^specs/scoring/FEAT-[0-9]{4}\\.json$"
        },
        "decision_file": {
          "type": "string",
          "pattern": "^specs/decision/FEAT-[0-9]{4}\\.md$"
        }
      }
    }
  }
}
